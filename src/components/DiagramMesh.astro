---
// Peer-to-peer mesh with state-sync primitives labelled.
const { caption = 'Every instance peers directly. State stays consistent with bloom filters, merkle trees, and vector clocks.' } = Astro.props;
const nodes = [
  { x: 130, y: 60 }, { x: 320, y: 40 }, { x: 500, y: 70 },
  { x: 90, y: 210 }, { x: 300, y: 240 }, { x: 520, y: 205 },
];
const edges = [
  [0,1],[1,2],[0,3],[1,4],[2,5],[3,4],[4,5],[0,4],[2,4],[1,3],[1,5],
];
---
<div class="diagram">
  <svg viewBox="0 0 620 300" role="img" aria-label="Peer-to-peer NNG mesh of six RevenProx instances synchronizing state">
    <defs>
      <linearGradient id="mx-accent" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#f7a41d" /><stop offset="1" stop-color="#ff7847" />
      </linearGradient>
    </defs>
    {edges.map(([a, b]) => (
      <line x1={nodes[a].x} y1={nodes[a].y} x2={nodes[b].x} y2={nodes[b].y} stroke="url(#mx-accent)" stroke-width="1.1" opacity="0.45" />
    ))}
    {nodes.map((n, i) => (
      <g>
        <circle cx={n.x} cy={n.y} r="26" class="d-node-fill" stroke="url(#mx-accent)" stroke-width="1.8" />
        <text x={n.x} y={n.y + 4} text-anchor="middle" class="d-sub">rp-{i + 1}</text>
      </g>
    ))}
    <g class="d-sub" text-anchor="middle">
      <text x="310" y="290">bloom filters · merkle trees · vector clocks — no coordinator</text>
    </g>
  </svg>
  <p class="cap">{caption}</p>
</div>
