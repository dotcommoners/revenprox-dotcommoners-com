---
// Renders a visible breadcrumb trail. `items` = [{ label, href? }]; the last
// item is treated as the current page. Matching BreadcrumbList JSON-LD is
// emitted by pages via the schema helper in site.js.
const { items = [] } = Astro.props;
---
<nav class="crumbs wrap" aria-label="Breadcrumb">
  <ol>
    {items.map((it, i) => (
      <li>
        {it.href && i < items.length - 1
          ? <a href={it.href}>{it.label}</a>
          : <span aria-current="page">{it.label}</span>}
      </li>
    ))}
  </ol>
</nav>
