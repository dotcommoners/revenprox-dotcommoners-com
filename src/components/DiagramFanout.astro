---
// SSE fan-out: one publisher -> mesh -> millions of clients, routed by topic.
const { caption = 'One publish, routed by UUID topic, fanned out to the right subscribers — no central broker.' } = Astro.props;
---
<div class="diagram">
  <svg viewBox="0 0 720 300" role="img" aria-label="SSE fan-out diagram: a publisher sends an event through the RevenProx mesh to the subscribed clients">
    <defs>
      <linearGradient id="fx-accent" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="#f7a41d" /><stop offset="1" stop-color="#ff7847" />
      </linearGradient>
    </defs>

    <!-- Publisher -->
    <rect x="20" y="120" width="120" height="58" rx="10" class="d-node-fill d-stroke" stroke-width="1.5" />
    <text x="80" y="146" text-anchor="middle" class="d-label">Publisher</text>
    <text x="80" y="164" text-anchor="middle" class="d-sub">publish(topic)</text>

    <!-- arrow to mesh -->
    <path d="M140 149 H210" stroke="url(#fx-accent)" stroke-width="2" fill="none" marker-end="url(#fx-arrow)" />
    <defs>
      <marker id="fx-arrow" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto">
        <path d="M0 0 L9 4.5 L0 9 z" fill="#ff7847" />
      </marker>
    </defs>

    <!-- Mesh (3 nodes) -->
    <g>
      <circle cx="290" cy="90" r="30" class="d-node-fill" stroke="url(#fx-accent)" stroke-width="1.8" />
      <circle cx="360" cy="180" r="30" class="d-node-fill" stroke="url(#fx-accent)" stroke-width="1.8" />
      <circle cx="270" cy="220" r="30" class="d-node-fill" stroke="url(#fx-accent)" stroke-width="1.8" />
      <path d="M290 120 L360 150 M290 120 L270 190 M360 210 L300 220" class="d-accent" stroke-width="1.2" stroke-dasharray="3 3" fill="none" opacity="0.7" />
      <text x="290" y="94" text-anchor="middle" class="d-sub">rp-1</text>
      <text x="360" y="184" text-anchor="middle" class="d-sub">rp-2</text>
      <text x="270" y="224" text-anchor="middle" class="d-sub">rp-3</text>
    </g>
    <text x="315" y="30" text-anchor="middle" class="d-label">Brokerless NNG mesh</text>

    <!-- arrows to clients -->
    <path d="M320 82 C440 40, 520 40, 590 52" class="d-accent" stroke-width="1.6" fill="none" marker-end="url(#fx-arrow)" opacity="0.9" />
    <path d="M388 170 C480 140, 540 130, 590 128" class="d-accent" stroke-width="1.6" fill="none" marker-end="url(#fx-arrow)" opacity="0.9" />
    <path d="M296 235 C440 260, 520 240, 590 210" class="d-accent" stroke-width="1.6" fill="none" marker-end="url(#fx-arrow)" opacity="0.9" />

    <!-- Clients -->
    <g>
      <rect x="590" y="34" width="110" height="40" rx="8" class="d-node-fill d-stroke" stroke-width="1.5" />
      <text x="645" y="59" text-anchor="middle" class="d-sub">clients · topic A</text>
      <rect x="590" y="110" width="110" height="40" rx="8" class="d-node-fill d-stroke" stroke-width="1.5" />
      <text x="645" y="135" text-anchor="middle" class="d-sub">clients · topic B</text>
      <rect x="590" y="190" width="110" height="40" rx="8" class="d-node-fill d-stroke" stroke-width="1.5" />
      <text x="645" y="215" text-anchor="middle" class="d-sub">10M+ SSE conns</text>
    </g>
  </svg>
  <p class="cap">{caption}</p>
</div>
